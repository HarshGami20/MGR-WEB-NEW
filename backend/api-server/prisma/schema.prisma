generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  address   String?
  city      String?
  state     String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  users          User[]
  userBranches   UserBranch[]
  orders         Order[]
  purchaseOrders PurchaseOrder[]
  inventoryLogs  InventoryLog[]
  deliverySlots  DeliverySlot[]
  complaints     Complaint[]

  @@map("branches")
}

model DeliverySlot {
  id              Int      @id @default(autoincrement())
  branchId        Int      @map("branch_id")
  slotDate        DateTime @map("slot_date") @db.Date
  label           String
  startTime       String   @map("start_time")
  endTime         String   @map("end_time")
  maxOrders       Int      @map("max_orders")
  /** JSON array of pincode strings; "[]" means any pincode */
  servicePincodes String   @default("[]") @map("service_pincodes")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([branchId, slotDate])
  @@map("delivery_slots")
}

model UserBranch {
  userId   Int @map("user_id")
  branchId Int @map("branch_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branches")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions String   @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  users User[]

  @@map("roles")
}

enum NotificationPriority {
  low
  normal
  high
  urgent

  @@map("notification_priority")
}

model User {
  id               Int      @id @default(autoincrement())
  name             String
  mobile           String   @unique
  email            String?
  avatarUrl        String?  @map("avatar_url")
  passwordHash     String   @map("password_hash")
  roleId           Int?     @map("role_id")
  branchId         Int?     @map("branch_id")
  supplierId       Int?     @map("supplier_id")
  manufacturerId   Int?     @map("manufacturer_id")
  isActive         Boolean  @default(true) @map("is_active")
  /// Sales staff: order list access can be restricted to assigned, created-by, or all orders.
  isSales          Boolean  @default(false) @map("is_sales")
  /// When `isSales` is true: `all` | `assigned_to_me` | `created_by_me`. Null when not sales.
  ordersListScope  String?  @map("orders_list_scope")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role           Role?         @relation(fields: [roleId], references: [id])
  branch         Branch?       @relation(fields: [branchId], references: [id])
  userBranches   UserBranch[]
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id])
  assignedOrders Order[]       @relation("OrderAssignee")
  createdOrders  Order[]       @relation("OrderCreatedBy")
  orderAssignees         OrderAssignee[]
  orderDeliveryAssignees OrderDeliveryAssignee[]
  createdComplaints     Complaint[]         @relation("ComplaintCreatedBy")
  complaintComments     ComplaintComment[]
  paymentFollowUps      PaymentFollowUp[]   @relation("PaymentFollowUpCreatedBy")
  paymentsRecorded      Payment[]           @relation("PaymentCreatedBy")

  notificationsSent       Notification[]           @relation("NotificationSender")
  notificationRecipients  NotificationRecipient[]
  fcmTokens                 UserFcmToken[]
  notificationPreference    NotificationPreference?

  @@map("users")
}

/// In-app + push notification root record (PostgreSQL/Prisma equivalent of a Mongo “notifications” collection document).
model Notification {
  id               String               @id @default(cuid())
  title            String
  message          String
  senderId         Int?                 @map("sender_id")
  notificationType String               @map("notification_type")
  module           String?
  metadata         Json                 @default("{}")
  priority         NotificationPriority @default(normal)
  /// Denormalized copy for list filters; per-user read state lives on NotificationRecipient.
  isBroadcast      Boolean              @default(false) @map("is_broadcast")
  scheduledAt      DateTime?            @map("scheduled_at") @db.Timestamptz(6)
  expiresAt        DateTime?            @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  sender       User?                     @relation("NotificationSender", fields: [senderId], references: [id])
  recipients   NotificationRecipient[]
  logs         NotificationLog[]

  @@index([createdAt(sort: Desc)])
  @@index([notificationType])
  @@index([module])
  @@map("notifications")
}

model NotificationRecipient {
  id             String    @id @default(cuid())
  notificationId String    @map("notification_id")
  userId         Int       @map("user_id")
  isRead         Boolean   @default(false) @map("is_read")
  readAt         DateTime? @map("read_at") @db.Timestamptz(6)

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, isRead])
  @@index([notificationId])
  @@map("notification_recipients")
}

model UserFcmToken {
  id        String   @id @default(cuid())
  userId    Int      @map("user_id")
  token     String   @unique
  platform  String
  deviceId  String?  @map("device_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_fcm_tokens")
}

model NotificationPreference {
  userId          Int      @id @map("user_id")
  pushEnabled     Boolean  @default(true) @map("push_enabled")
  socketEnabled   Boolean  @default(true) @map("socket_enabled")
  emailEnabled    Boolean  @default(false) @map("email_enabled")
  mutedModules    Json     @default("[]") @map("muted_modules")
  mutedTypes      Json     @default("[]") @map("muted_types")
  digestFrequency String   @default("instant") @map("digest_frequency")
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model NotificationLog {
  id             String   @id @default(cuid())
  notificationId String?  @map("notification_id")
  userId         Int?     @map("user_id")
  channel        String
  status         String
  detail         Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([notificationId])
  @@map("notification_logs")
}

/// Registry of notification type codes for validation and admin UI (optional seed).
model NotificationTypeDefinition {
  code        String   @id
  label       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("notification_type_definitions")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  parentId  Int?     @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  products Product[]

  @@map("categories")
}

model AttributeKey {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  options AttributeOption[]

  @@map("attribute_keys")
}

model AttributeOption {
  id        Int      @id @default(autoincrement())
  keyId     Int      @map("key_id")
  value     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  key AttributeKey @relation(fields: [keyId], references: [id], onDelete: Cascade)

  @@unique([keyId, value])
  @@map("attribute_options")
}

model Product {
  id               Int      @id @default(autoincrement())
  name             String
  sku              String   @unique
  categoryId       Int?     @map("category_id")
  imageUrl         String?  @map("image_url")
  /** JSON string array of image URLs */
  imageUrls        String?  @map("image_urls")
  price            Decimal  @db.Decimal(12, 2)
  gstPercent       Decimal  @default(18) @map("gst_percent") @db.Decimal(5, 2)
  stockQty         Int      @default(0) @map("stock_qty")
  lowStockThreshold Int     @default(10) @map("low_stock_threshold")
  description      String?
  /** JSON object of attribute key/value pairs (size, colour, fabric, etc.) for single-SKU products */
  attributes       String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  category           Category?            @relation(fields: [categoryId], references: [id])
  inventoryLogs      InventoryLog[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  variants           ProductVariant[]
  complaints         Complaint[]

  @@map("products")
}

model ProductVariant {
  id                Int      @id @default(autoincrement())
  productId         Int      @map("product_id")
  name              String
  sku               String   @unique
  imageUrl          String?  @map("image_url")
  /** JSON string array of image URLs */
  imageUrls         String?  @map("image_urls")
  price             Decimal? @db.Decimal(12, 2)
  stockQty          Int      @default(0) @map("stock_qty")
  lowStockThreshold Int      @default(10) @map("low_stock_threshold")
  attributes        String?
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryLogs InventoryLog[]
  purchaseOrderItems PurchaseOrderItem[]

  @@map("product_variants")
}

model InventoryLog {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  variantId Int?     @map("variant_id")
  branchId  Int?     @map("branch_id")
  type      String
  quantity  Int
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  branch  Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@map("inventory_logs")
}

model Order {
  id                Int      @id @default(autoincrement())
  orderNumber       String   @unique @map("order_number")
  customerName      String   @map("customer_name")
  customerMobile    String?  @map("customer_mobile")
  customerAddress   String?  @map("customer_address")
  isGst             Boolean  @default(false) @map("is_gst")
  customerGstNumber String?  @map("customer_gst_number")
  status            String   @default("order_received")
  paymentStatus     String   @default("due") @map("payment_status")
  advanceAmount     Decimal  @default(0) @map("advance_amount") @db.Decimal(12, 2)
  paymentMode       String?  @map("payment_mode")
  challanImages     String?  @map("challan_images")
  photoComments     String?  @map("photo_comments")
  staffComments     String?  @map("staff_comments")
  deliveryComments  String?  @map("delivery_comments")
  assignedToId      Int?     @map("assigned_to_id")
  createdById       Int?     @map("created_by_id")
  deliveryDate      DateTime? @map("delivery_date") @db.Timestamptz(6)
  subtotal          Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount       Decimal  @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount        Decimal  @default(0) @map("paid_amount") @db.Decimal(12, 2)
  notes             String?
  branchId          Int?     @map("branch_id")
  deliverySlotId    Int?     @map("delivery_slot_id")
  /** Logistics: pending | out_for_delivery | delivered (separate from main order status) */
  deliveryStatus    String   @default("pending") @map("delivery_status")
  customerPincode   String?  @map("customer_pincode")
  addressLat        Decimal? @map("address_lat") @db.Decimal(11, 8)
  addressLng        Decimal? @map("address_lng") @db.Decimal(11, 8)
  googlePlaceId     String?  @map("google_place_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  branch       Branch?       @relation(fields: [branchId], references: [id])
  deliverySlot DeliverySlot? @relation(fields: [deliverySlotId], references: [id], onDelete: SetNull)
  assignedTo   User?         @relation("OrderAssignee", fields: [assignedToId], references: [id])
  createdBy    User?         @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignees           OrderAssignee[]
  deliveryAssignees   OrderDeliveryAssignee[]
  items        OrderItem[]
  invoices     Invoice[]
  payments          Payment[]
  paymentFollowUps  PaymentFollowUp[]
  complaints        Complaint[]

  @@map("orders")
}

enum ComplaintStatus {
  open
  in_progress
  resolved

  @@map("complaint_status")
}

enum ComplaintKind {
  sales_order
  purchase_order

  @@map("complaint_kind")
}

model Complaint {
  id              Int             @id @default(autoincrement())
  complaintNumber String          @unique @map("complaint_number")
  kind            ComplaintKind   @default(sales_order)
  orderId         Int?            @map("order_id")
  purchaseOrderId Int?            @map("purchase_order_id")
  productId       Int?            @map("product_id")
  branchId        Int?            @map("branch_id")
  createdById     Int?            @map("created_by_id")
  subject         String?
  description     String
  status          ComplaintStatus @default(open)
  /** JSON string array of image URLs */
  imageUrls       String?         @map("image_urls")
  resolvedAt      DateTime?       @map("resolved_at") @db.Timestamptz(6)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  order         Order?             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  branch        Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy     User?              @relation("ComplaintCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  comments      ComplaintComment[]

  @@index([orderId])
  @@index([purchaseOrderId])
  @@index([kind, branchId, status])
  @@map("complaints")
}

model ComplaintComment {
  id          Int      @id @default(autoincrement())
  complaintId Int      @map("complaint_id")
  userId      Int      @map("user_id")
  body        String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@map("complaint_comments")
}

model OrderAssignee {
  orderId Int @map("order_id")
  userId  Int @map("user_id")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orderId, userId])
  @@index([userId])
  @@map("order_assignees")
}

/** Staff assigned to handle delivery / delivery-status updates for an order. */
model OrderDeliveryAssignee {
  orderId Int @map("order_id")
  userId  Int @map("user_id")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orderId, userId])
  @@index([userId])
  @@map("order_delivery_assignees")
}

model OrderItem {
  id               Int      @id @default(autoincrement())
  orderId          Int      @map("order_id")
  isCustom         Boolean  @default(false) @map("is_custom")
  productId        Int?     @map("product_id")
  customName       String?  @map("custom_name")
  customImageUrl   String?  @map("custom_image_url")
  /** JSON string array of image URLs for custom lines */
  customImageUrls  String?  @map("custom_image_urls")
  customAttributes String?  @map("custom_attributes")
  description      String?
  quantity         Int
  unitPrice        Decimal  @map("unit_price") @db.Decimal(12, 2)
  gstPercent       Decimal  @default(0) @map("gst_percent") @db.Decimal(5, 2)
  totalPrice       Decimal  @map("total_price") @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNumber String   @unique @map("invoice_number")
  orderId       Int      @map("order_id")
  isGst         Boolean  @default(false) @map("is_gst")
  cgst          Decimal  @default(0) @db.Decimal(12, 2)
  sgst          Decimal  @default(0) @db.Decimal(12, 2)
  igst          Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal  @default(0) @map("total_amount") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id])

  @@map("invoices")
}

model Payment {
  id           Int      @id @default(autoincrement())
  orderId      Int      @map("order_id")
  amount       Decimal  @db.Decimal(12, 2)
  mode         String   @default("cash")
  chequeNumber String?  @map("cheque_number")
  notes        String?
  createdById  Int?     @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order     Order @relation(fields: [orderId], references: [id])
  createdBy User? @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@map("payments")
}

model PaymentFollowUp {
  id           Int      @id @default(autoincrement())
  orderId      Int      @map("order_id")
  followUpDate DateTime @map("follow_up_date") @db.Date
  note         String
  createdById  Int?     @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User? @relation("PaymentFollowUpCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([followUpDate])
  @@map("payment_follow_ups")
}

model Supplier {
  id            Int      @id @default(autoincrement())
  name          String
  contactPerson String?  @map("contact_person")
  mobile        String?
  email         String?
  address       String?
  gstNumber     String?  @map("gst_number")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  purchaseOrders PurchaseOrder[]
  users          User[]

  @@map("suppliers")
}

model Manufacturer {
  id            Int      @id @default(autoincrement())
  name          String
  contactPerson String?  @map("contact_person")
  mobile        String?
  email         String?
  address       String?
  specialization String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  purchaseOrders PurchaseOrder[]
  users          User[]

  @@map("manufacturers")
}

model PurchaseOrder {
  id               Int      @id @default(autoincrement())
  poNumber         String   @unique @map("po_number")
  type             String
  supplierId       Int?     @map("supplier_id")
  manufacturerId   Int?     @map("manufacturer_id")
  status           String   @default("pending")
  totalAmount      Decimal  @default(0) @map("total_amount") @db.Decimal(12, 2)
  expectedDelivery DateTime? @map("expected_delivery") @db.Timestamptz(6)
  notes            String?
  /** JSON array: { comment, authorName?, createdAt } */
  staffComments    String?  @map("staff_comments")
  branchId         Int?     @map("branch_id")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  supplier     Supplier?           @relation(fields: [supplierId], references: [id])
  manufacturer Manufacturer?       @relation(fields: [manufacturerId], references: [id])
  branch       Branch?             @relation(fields: [branchId], references: [id])
  items        PurchaseOrderItem[]
  complaints   Complaint[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               Int      @id @default(autoincrement())
  purchaseOrderId  Int      @map("purchase_order_id")
  isCustom         Boolean  @default(false) @map("is_custom")
  productId        Int?     @map("product_id")
  variantId        Int?     @map("variant_id")
  customName       String?  @map("custom_name")
  customImageUrl   String?  @map("custom_image_url")
  /** JSON string array of image URLs for custom lines */
  customImageUrls  String?  @map("custom_image_urls")
  customAttributes String?  @map("custom_attributes")
  description      String?
  quantity         Int
  unitPrice        Decimal  @map("unit_price") @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?        @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("purchase_order_items")
}

model Setting {
  id                Int      @id @default(autoincrement())
  companyName       String   @default("Furniture Co.") @map("company_name")
  gstNumber         String?  @map("gst_number")
  address           String?
  phone             String?
  email             String?
  defaultGstPercent Decimal  @default(18) @map("default_gst_percent") @db.Decimal(5, 2)
  invoicePrefix     String   @default("INV") @map("invoice_prefix")
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("settings")
}
