{
  "name": "api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && npm run build && node --env-file=.env --enable-source-maps ./dist/index.mjs",
    "build": "prisma generate && node ./build.mjs",
    "start": "prisma generate && node --env-file=.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:psql": "bash scripts/psql.sh",
    "prisma:migrate:dev": "prisma migrate dev",
    "seed": "prisma db seed",
    "seed:admin": "tsx prisma/seed-admin-only.ts",
    "clear:stock": "tsx --env-file=.env prisma/clear-stock.ts",
    "recalc:order-totals": "tsx --env-file=.env prisma/recalc-order-totals.ts",
    "worker:notifications": "node --env-file=.env --enable-source-maps ./dist/workers/notification-worker.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.6",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "express": "^5",
    "express-rate-limit": "^8.5.1",
    "firebase-admin": "^13.9.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pino": "^9",
    "pino-http": "^10",
    "socket.io": "^4.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/pdf-parse": "^1.1.5",
    "esbuild": "0.25.8",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "prisma": "^6.7.0",
    "thread-stream": "3.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
