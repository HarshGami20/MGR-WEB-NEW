NODE_ENV=development
DATABASE_URL=postgresql://postgres:root@localhost:5432/furniture-erp?schema=public
PORT=3000
# REDIS_URL=redis://localhost:6379
REDIS_URL=redis://127.0.0.1:6379
SOCKET_BRIDGE_CHANNEL=socket-bridge
SESSION_SECRET=furniture-erp-secret-key


# FIREBASE_SERVICE_ACCOUNT_JSON=firebase-service-account.json
# FIREBASE_API_KEY=firebase-api-key
# FIREBASE_AUTH_DOMAIN=firebase-auth-domain
# FIREBASE_PROJECT_ID=firebase-project-id
# FIREBASE_STORAGE_BUCKET=firebase-storage-bucket
# FIREBASE_MESSAGING_SENDER_ID=firebase-messaging-sender-id
# FIREBASE_APP_ID=firebase-app-id
# FIREBASE_VAPID_KEY=firebase-vapid-key

# cd backend/api-server && npm install && npx prisma generate && npx prisma db push
# export PORT=8080 DATABASE_URL='postgresql://postgres:root@localhost:5432/furniture-erp?schema=public' SESSION_SECRET='...'
# npm run dev



# Firebase Admin — path to service account JSON file (same folder as this API project).
# Use ./filename when you start the server from backend/api-server (npm run dev).
# WRONG: leading slash only (e.g. /mgr-casa-...) points at the OS root, not your project.
GOOGLE_APPLICATION_CREDENTIALS=./mgr-casa-firebase-adminsdk-fbsvc-0e1702917b.json

# Send FCM from this API process (skip BullMQ worker). Use when REDIS_URL is set but you do not run `npm run worker:notifications`.
# For production, omit this and run the worker instead.
NOTIFICATION_PUSH_INLINE=true

# Optional alternative: single-line JSON only — do not use multiline in .env.
# If set, firebase-admin loads this FIRST (omit GOOGLE_APPLICATION_CREDENTIALS or leave unset).
# FIREBASE_SERVICE_ACCOUNT_JSON=
